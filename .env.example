# Weather — uses Open-Meteo (free, no API key needed)
# Find your coordinates at: https://www.latlong.net
WEATHER_LAT=40.71
WEATHER_LON=-74.01
WEATHER_LOCATION_NAME=New York City

# Google Calendar — OAuth2 (one-time browser authorization)
# Option A: point at the credentials.json downloaded from Google Cloud Console
#   console.cloud.google.com → APIs & Services → Credentials → Desktop app
# GOOGLE_CREDENTIALS_JSON=/path/to/credentials.json
#
# Option B: paste the values directly
# GOOGLE_CLIENT_ID=123456789-xxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-xxx
#
# Calendar to show (your email = primary calendar)
# GOOGLE_CALENDAR_ID=primary

# Comma-separated RSS feed URLs
RSS_FEEDS=https://feeds.bbci.co.uk/news/rss.xml,https://hnrss.org/frontpage
